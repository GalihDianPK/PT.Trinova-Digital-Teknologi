---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Founders from '../components/Founders.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

// ===== HERO DATA =====
// Edit these values to change the hero section content
const hero = {
  title: "Transforming Business Through Digital Intelligence",
  description: "Kami mengintegrasikan analisis bisnis dan teknologi mutakhir untuk menciptakan solusi strategis yang berkelanjutan bagi perusahaan Anda. Bersama kami, ambil keputusan lebih cerdas berbasis data.",
  ctaPrimary: { text: "Explore Solutions", href: "#services" },
  ctaSecondary: { text: "Consult With Us", href: "#contact" },
};

// ===== ABOUT DATA =====
// Edit these values to change the about section content
const about = {
  title: "Sejarah Singkat PT TriNova Digital Teknologi",
  paragraphs: [
    "PT TriNova Digital Teknologi merupakan perusahaan yang bergerak di bidang IT Consultant dan Business Analyst yang didirikan atas dasar kesamaan visi tiga pendirinya, yaitu Bagus, Krisna, dan Galih. Berbekal minat dan pengalaman di bidang teknologi informasi, mereka melihat semakin besarnya kebutuhan perusahaan dan organisasi terhadap solusi digital yang mampu meningkatkan efisiensi, produktivitas, serta daya saing di era transformasi digital. Dari pemikiran tersebut lahirlah sebuah perusahaan yang berkomitmen untuk menjadi mitra strategis dalam pengembangan teknologi informasi.",
    "Nama TriNova memiliki makna yang mendalam. Kata \"Tri\" melambangkan tiga pendiri yang menjadi fondasi utama perusahaan, sedangkan \"Nova\" berarti bintang baru atau inovasi baru yang mencerminkan semangat perusahaan untuk terus berkembang dan menciptakan terobosan di bidang teknologi. Nama tersebut dipilih sebagai simbol kolaborasi, kreativitas, dan tekad untuk menghadirkan solusi yang relevan dengan kebutuhan dunia bisnis modern.",
    "Sejak awal berdiri, PT TriNova Digital Teknologi memfokuskan layanan pada konsultasi teknologi informasi dan analisis bisnis. Perusahaan membantu klien dalam memahami proses bisnis yang sedang berjalan, mengidentifikasi berbagai permasalahan, serta merancang solusi digital yang tepat dan berkelanjutan. Melalui pendekatan berbasis data dan teknologi, perusahaan berupaya mendukung pengambilan keputusan yang lebih efektif sehingga dapat memberikan nilai tambah bagi setiap klien yang dilayani.",
    "Dengan mengusung slogan \"Three Minds and One Innovation\", PT TriNova Digital Teknologi terus berkomitmen untuk menghadirkan inovasi yang bermanfaat bagi dunia usaha. Perusahaan menjunjung tinggi nilai profesionalisme, kepercayaan, kerja sama tim, dan inovasi berkelanjutan dalam setiap layanan yang diberikan. Ke depan, PT TriNova Digital Teknologi bertekad untuk menjadi perusahaan konsultan teknologi informasi yang unggul dalam menyediakan solusi strategis berbasis digital guna membantu klien mencapai pertumbuhan dan kesuksesan yang berkelanjutan."
  ],
  stats: [
    { value: "50+", label: "Enterprise Clients" },
    { value: "98%", label: "Project Success Rate" },
  ],
};

// ===== FOUNDERS DATA =====
// Edit these values to change the founders section content
const founders = {
  title: "Meet Our Visionaries",
  subtitle: "Kepemimpinan yang berdedikasi untuk mendorong inovasi dan kesuksesan teknologi bisnis Anda.",
  members: [
    {
      name: "Bagus Alkahfi P.E, S.Kom.",
      role: "Chief Executive Officer (CEO)",
      image: "/images/founder-ceo.png",
      bio: "Mengarahkan visi strategis Trinova Digital untuk memberdayakan bisnis melalui teknologi cerdas."
    },
    {
      name: "Galih Dian P.K, S.Kom.",
      role: "Chief Technology Officer (CTO)",
      image: "/images/founder-cto.png",
      bio: "Memimpin pengembangan solusi teknologi inovatif dan memastikan standar arsitektur terbaik."
    },
    {
      name: "Krisna Adnan Islami, S.Kom.",
      role: "Chief Financial Officer (CFO)",
      image: "/images/founder-cfo.png",
      bio: "Mengatur keuangan perusahaan dan memastikan kesehatan finansial perusahaan serta mendukung strategi pertumbuhan bisnis."
    }
  ]
};

// ===== CONTACT DATA =====
// Edit these values to change the contact section content
const contact = {
  title: "Initiate Transformation",
  description: "Connect with our consultants to discuss your architectural challenges and explore technological solutions tailored for your enterprise.",
  hqTitle: "Headquarters",
  hqAddress: "Plaza Indonesia, Jl. M.H. Thamrin No.Kav. 28-30<br/>Menteng, Jakarta Pusat 10350",
  mapLink: "https://maps.app.goo.gl/wvH5mcUD5dzSm8jy7",
};

// ===== FOOTER DATA =====
// Edit these values to change the footer content
const footer = {
  tagline: "Transforming Business Through Digital Intelligence. Architecting high-performance enterprise technology solutions.",
  copyright: "© 2024 PT Trinova Digital Teknologi.<br/>All rights reserved.",
  linkGroups: [
    {
      title: "Legal",
      links: [
        { text: "Privacy Policy", href: "#" },
        { text: "Terms of Service", href: "#" },
        { text: "Cookie Policy", href: "#" },
        { text: "Security", href: "#" },
      ],
    },
    {
      title: "Company",
      links: [
        { text: "About Us", href: "#about" },
        { text: "Services", href: "#services" },
        { text: "Contact", href: "#contact" },
      ],
    },
    {
      title: "Connect",
      links: [
        { text: "LinkedIn", href: "#" },
        { text: "Twitter", href: "#" },
      ],
    },
  ],
};
---

<Layout>
  <Navbar />
  <main class="pt-24">
    <Hero {...hero} />
    <About {...about} />
    <Services />
    <Founders {...founders} />
    <Contact {...contact} />
  </main>
  <Footer {...footer} />
</Layout>
