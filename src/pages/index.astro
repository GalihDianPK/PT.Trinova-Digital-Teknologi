---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import History from '../components/History.astro';
import Services from '../components/Services.astro';
import Founders from '../components/Founders.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

// ===== HERO DATA =====
// Edit these values to change the hero section content
const hero = {
  title: "Transforming Business Through Digital Intelligence",
  description: "Kami mengintegrasikan analisis bisnis dan teknologi mutakhir untuk menciptakan solusi strategis yang berkelanjutan bagi perusahaan Anda. Bersama kami, ambil keputusan lebih cerdas berbasis data.",
  ctaPrimary: { text: "Explore Solutions", href: "#services" },
  ctaSecondary: { text: "Consult With Us", href: "#contact" },
};

// ===== ABOUT DATA =====
// Edit these values to change the about section content
const about = {
  title: "Architecting the Future of Enterprise",
  paragraphs: [
    "PT Trinova Digital Teknologi membangun identitas perusahaan berkinerja tinggi untuk perusahaan konsultan TI terkemuka. Kami memadukan ketelitian arsitektur teknologi perusahaan dengan estetika futuristik dan berwawasan ke depan.",
    'Pendekatan "Kecerdasan Profesional" kami menyeimbangkan stabilitas akar perusahaan yang kuat dengan kelincahan inovasi yang berkelas, memastikan transformasi digital yang tangguh dan terukur.',
  ],
  stats: [
    { value: "50+", label: "Enterprise Clients" },
    { value: "98%", label: "Project Success Rate" },
  ],
};

// ===== FOUNDERS DATA =====
// Edit these values to change the founders section content
const founders = {
  title: "Meet Our Visionaries",
  subtitle: "Kepemimpinan yang berdedikasi untuk mendorong inovasi dan kesuksesan teknologi bisnis Anda.",
  members: [
    {
      name: "Bagus Alkahfi P.E, S.Kom.",
      role: "Chief Executive Officer (CEO)",
      image: "/images/founder-ceo.png",
      bio: "Mengarahkan visi strategis Trinova Digital untuk memberdayakan bisnis melalui teknologi cerdas."
    },
    {
      name: "Galih Dian P.K, S.Kom.",
      role: "Chief Technology Officer (CTO)",
      image: "/images/founder-cto.png",
      bio: "Memimpin pengembangan solusi teknologi inovatif dan memastikan standar arsitektur terbaik."
    },
    {
      name: "Krisna Adnan Islami, S.Kom.",
      role: "Chief Financial Officer (CFO)",
      image: "/images/founder-cfo.png",
      bio: "Mengatur keuangan perusahaan dan memastikan kesehatan finansial perusahaan serta mendukung strategi pertumbuhan bisnis."
    }
  ]
};

// ===== CONTACT DATA =====
// Edit these values to change the contact section content
const contact = {
  title: "Initiate Transformation",
  description: "Connect with our consultants to discuss your architectural challenges and explore technological solutions tailored for your enterprise.",
  hqTitle: "Headquarters",
  hqAddress: "Plaza Indonesia, Jl. M.H. Thamrin No.Kav. 28-30<br/>Menteng, Jakarta Pusat 10350",
  mapLink: "https://maps.app.goo.gl/wvH5mcUD5dzSm8jy7",
};

// ===== FOOTER DATA =====
// Edit these values to change the footer content
const footer = {
  tagline: "Transforming Business Through Digital Intelligence. Architecting high-performance enterprise technology solutions.",
  copyright: "© 2024 PT Trinova Digital Teknologi.<br/>All rights reserved.",
  linkGroups: [
    {
      title: "Legal",
      links: [
        { text: "Privacy Policy", href: "#" },
        { text: "Terms of Service", href: "#" },
        { text: "Cookie Policy", href: "#" },
        { text: "Security", href: "#" },
      ],
    },
    {
      title: "Company",
      links: [
        { text: "About Us", href: "#about" },
        { text: "Sejarah", href: "#history" },
        { text: "Services", href: "#services" },
        { text: "Contact", href: "#contact" },
      ],
    },
    {
      title: "Connect",
      links: [
        { text: "LinkedIn", href: "#" },
        { text: "Twitter", href: "#" },
      ],
    },
  ],
};
---

<Layout>
  <Navbar />
  <main class="pt-24">
    <Hero {...hero} />
    <About {...about} />
    <History />
    <Services />
    <Founders {...founders} />
    <Contact {...contact} />
  </main>
  <Footer {...footer} />
</Layout>
