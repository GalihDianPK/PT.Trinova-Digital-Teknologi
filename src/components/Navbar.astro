---
// Navbar component with scroll spy for active link indicator
---

<nav class="bg-white/80 backdrop-blur-md fixed top-0 w-full z-50 border-b border-outline-variant/50 transition-all duration-300 ease-in-out">
  <div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop py-5 max-w-container-max mx-auto">
    <a href="/" class="flex items-center gap-2">
      <img src="/images/logo.png" alt="PT Trinova Digital Teknologi" class="h-10 w-auto" />
      <span class="font-heading text-xl font-bold tracking-tight text-primary-container">Trinova Digital</span>
    </a>
    
    <!-- Desktop Navigation -->
    <div class="hidden md:flex gap-10 items-center text-sm font-medium" id="nav-links">
      <a class="nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200 pb-1 border-b-2 border-transparent" href="/#home" data-section="home">Home</a>
      
      <!-- Clean Hover Dropdown Container -->
      <div class="relative group" id="about-dropdown-container">
        <a class="nav-link flex items-center gap-0.5 text-on-surface-variant hover:text-primary-container transition-colors duration-200 pb-1 border-b-2 border-transparent cursor-pointer" href="/tentang-trinova#profil" id="about-dropdown-btn">
          Tentang Trinova
          <span class="material-symbols-outlined text-base transition-transform duration-200 group-hover:rotate-180" id="dropdown-arrow">keyboard_arrow_down</span>
        </a>
        <!-- Minimalist Glassmorphic Dropdown Menu -->
        <div class="absolute left-0 mt-1 w-48 bg-white/95 backdrop-blur-md border border-outline-variant/60 rounded-xl shadow-lg opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transform translate-y-2 group-hover:translate-y-0 transition-all duration-200 z-50 flex flex-col p-1.5" id="about-dropdown-menu">
          <a class="dropdown-item px-4 py-2 rounded-lg text-xs font-semibold text-on-surface-variant hover:text-primary-container hover:bg-surface-container-low transition-colors duration-150" href="/tentang-trinova#profil">Profil Trinova</a>
          <a class="dropdown-item px-4 py-2 rounded-lg text-xs font-semibold text-on-surface-variant hover:text-primary-container hover:bg-surface-container-low transition-colors duration-150" href="/tentang-trinova#sejarah">Sejarah</a>
          <a class="dropdown-item px-4 py-2 rounded-lg text-xs font-semibold text-on-surface-variant hover:text-primary-container hover:bg-surface-container-low transition-colors duration-150" href="/tentang-trinova#visi-misi">Visi & Misi</a>
        </div>
      </div>

      <a class="nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200 pb-1 border-b-2 border-transparent" href="/#services" data-section="services">Services</a>
      <a class="nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200 pb-1 border-b-2 border-transparent" href="/#founders" data-section="founders">Founders</a>
      <a class="nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200 pb-1 border-b-2 border-transparent" href="/#contact" data-section="contact">Contact</a>
    </div>

    <div class="hidden md:block">
      <a class="btn-primary px-5 py-2.5 rounded-md text-sm font-semibold tracking-wide" href="/#contact">Book Consultation</a>
    </div>
    
    <button class="md:hidden text-primary-container" id="mobile-menu-btn">
      <span class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div class="fixed inset-0 bg-primary/20 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300 md:hidden" id="mobile-menu-overlay"></div>
<!-- Mobile Menu Drawer -->
<div class="fixed right-0 top-0 h-full w-[280px] bg-white border-l border-outline-variant/50 z-50 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col p-6 shadow-2xl" id="mobile-menu-drawer">
  <div class="flex justify-between items-center mb-8">
    <span class="font-heading text-lg font-bold text-primary-container">Menu</span>
    <button class="text-primary-container" id="mobile-menu-close">
      <span class="material-symbols-outlined text-2xl">close</span>
    </button>
  </div>
  <div class="flex flex-col gap-6 text-base font-semibold" id="mobile-nav-links">
    <a class="mobile-nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="/#home" data-section="home">Home</a>
    
    <!-- Mobile Accordion for Tentang Trinova -->
    <div class="flex flex-col">
      <button class="mobile-nav-link flex items-center justify-between text-on-surface-variant hover:text-primary-container text-left transition-colors duration-200 w-full" id="mobile-about-btn">
        Tentang Trinova
        <span class="material-symbols-outlined transition-transform duration-200" id="mobile-arrow">keyboard_arrow_down</span>
      </button>
      <div class="flex flex-col pl-4 gap-3 mt-3 hidden" id="mobile-about-submenu">
        <a class="mobile-dropdown-item text-sm text-on-surface-variant hover:text-primary-container py-1 transition-colors duration-150" href="/tentang-trinova#profil">Profil Trinova</a>
        <a class="mobile-dropdown-item text-sm text-on-surface-variant hover:text-primary-container py-1 transition-colors duration-150" href="/tentang-trinova#sejarah">Sejarah</a>
        <a class="mobile-dropdown-item text-sm text-on-surface-variant hover:text-primary-container py-1 transition-colors duration-150" href="/tentang-trinova#visi-misi">Visi & Misi</a>
      </div>
    </div>

    <a class="mobile-nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="/#services" data-section="services">Services</a>
    <a class="mobile-nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="/#founders" data-section="founders">Founders</a>
    <a class="mobile-nav-link text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="/#contact" data-section="contact">Contact</a>
  </div>
  <div class="mt-auto">
    <a class="btn-primary w-full text-center block px-5 py-3 rounded-md text-sm font-semibold tracking-wide" href="/#contact">Book Consultation</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Desktop Dropdown references
    const aboutDropdownBtn = document.getElementById('about-dropdown-btn');
    const aboutDropdownMenu = document.getElementById('about-dropdown-menu');
    
    // Mobile Drawer references
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
    const mobileMenuDrawer = document.getElementById('mobile-menu-drawer');
    const mobileAboutBtn = document.getElementById('mobile-about-btn');
    const mobileAboutSubmenu = document.getElementById('mobile-about-submenu');
    const mobileArrow = document.getElementById('mobile-arrow');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link[href], .mobile-dropdown-item');

    // General navigation references
    const navLinks = document.querySelectorAll('.nav-link[href]');
    const sections = document.querySelectorAll('section[id]');

    // 1. Mobile Drawer Logic
    if (mobileMenuBtn && mobileMenuClose && mobileMenuOverlay && mobileMenuDrawer) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenuOverlay.classList.remove('hidden');
        void mobileMenuOverlay.offsetHeight;
        mobileMenuOverlay.classList.add('opacity-100');
        mobileMenuDrawer.classList.remove('translate-x-full');
      });

      const closeDrawer = () => {
        mobileMenuOverlay.classList.remove('opacity-100');
        mobileMenuDrawer.classList.add('translate-x-full');
        setTimeout(() => {
          mobileMenuOverlay.classList.add('hidden');
        }, 300);
      };

      mobileMenuClose.addEventListener('click', closeDrawer);
      mobileMenuOverlay.addEventListener('click', closeDrawer);

      // Mobile Accordion Toggle for Tentang Trinova
      if (mobileAboutBtn && mobileAboutSubmenu && mobileArrow) {
        mobileAboutBtn.addEventListener('click', (e) => {
          const isCollapsed = mobileAboutSubmenu.classList.contains('hidden');
          
          if (isCollapsed) {
            mobileAboutSubmenu.classList.remove('hidden');
            mobileArrow.classList.add('rotate-180');
          } else {
            mobileAboutSubmenu.classList.add('hidden');
            mobileArrow.classList.remove('rotate-180');
          }
        });
      }

      // Close drawer on clicking mobile links
      mobileNavLinks.forEach(link => {
        link.addEventListener('click', closeDrawer);
      });
    }

    // 2. Active Indicator & Scroll Spy
    function setActiveLink(activeSectionId: string) {
      const isTentangPage = window.location.pathname.includes('tentang-trinova');

      navLinks.forEach(link => {
        const linkHref = link.getAttribute('href') || '';
        
        if (isTentangPage) {
          // If on the tentang page, Tentang Trinova item is active
          if (link.id === 'about-dropdown-btn') {
            link.classList.remove('text-on-surface-variant', 'border-transparent');
            link.classList.add('text-primary-container', 'border-secondary');
          } else {
            link.classList.remove('text-primary-container', 'border-secondary');
            link.classList.add('text-on-surface-variant', 'border-transparent');
          }
        } else {
          // On the main page, highlight sections
          const sectionTarget = linkHref.split('#')[1];
          if (sectionTarget === activeSectionId) {
            link.classList.remove('text-on-surface-variant', 'border-transparent');
            link.classList.add('text-primary-container', 'border-secondary');
          } else {
            link.classList.remove('text-primary-container', 'border-secondary');
            link.classList.add('text-on-surface-variant', 'border-transparent');
          }
        }
      });
    }

    // Initialize active link
    const isTentangPage = window.location.pathname.includes('tentang-trinova');
    if (isTentangPage) {
      setActiveLink('tentang-trinova');
    } else {
      setActiveLink('home');

      // Setup Scroll Spy for the main page sections
      const observerOptions = {
        root: null,
        rootMargin: '-20% 0px -60% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            setActiveLink(entry.target.id);
          }
        });
      }, observerOptions);

      sections.forEach(section => {
        observer.observe(section);
      });
    }
  });
</script>


