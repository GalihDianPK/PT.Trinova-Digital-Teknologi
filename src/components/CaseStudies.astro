---
import { getCollection, render } from 'astro:content';

const caseStudies = (await getCollection('case-studies')).sort((a, b) => a.data.order - b.data.order);
const largeCaseStudy = caseStudies.find(c => c.data.size === 'large');
const smallCaseStudies = caseStudies.filter(c => c.data.size === 'small');

// Pre-render all content
let LargeContent: any = null;
if (largeCaseStudy) {
  const { Content } = await render(largeCaseStudy);
  LargeContent = Content;
}

const smallRendered = await Promise.all(
  smallCaseStudies.map(async (cs) => {
    const { Content } = await render(cs);
    return { cs, Content };
  })
);
---

<section class="py-section-py px-margin-mobile md:px-margin-desktop bg-[#00020a] text-white border-y border-white/5 reveal" id="case-studies">
  <div class="max-w-container-max mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-6">Proven Impact</h2>
        <p class="text-lg text-white/70 leading-relaxed">Real-world examples of how our Professional Intelligence methodology translates into measurable business success.</p>
      </div>
      <a class="border border-white/20 px-6 py-3 rounded-md text-sm font-semibold hover:bg-white/5 transition-colors shrink-0" href="#">View All Cases</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 grid-rows-2 gap-6 h-auto md:h-[640px]">
      {/* Large Bento Item */}
      {largeCaseStudy && LargeContent && (
        <div class="md:col-span-2 md:row-span-2 relative rounded-2xl overflow-hidden enterprise-card-dark group border border-white/10">
          <div
            class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105 opacity-60"
            style={`background-image: url('${largeCaseStudy.data.image}')`}
          ></div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#00020a] via-[#00020a]/80 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-10 w-full">
            <div class="flex gap-3 mb-6">
              {largeCaseStudy.data.tags.map((tag: string, i: number) => (
                <span class={`${i === 0 ? 'bg-secondary/20 text-secondary border-secondary/30' : 'bg-white/10 text-white border-white/20'} border px-3 py-1 rounded text-xs font-semibold tracking-wide uppercase`}>
                  {tag}
                </span>
              ))}
            </div>
            <h3 class="font-heading text-3xl font-bold mb-4">{largeCaseStudy.data.title}</h3>
            <div class="text-base text-white/70 max-w-xl leading-relaxed">
              <LargeContent />
            </div>
          </div>
        </div>
      )}

      {/* Small Bento Items */}
      {smallRendered.map(({ cs, Content }) => (
        <div class="rounded-2xl p-8 flex flex-col justify-between enterprise-card-dark border border-white/10">
          <div>
            <div class="w-10 h-10 border border-white/10 rounded-lg flex items-center justify-center mb-6 text-white bg-white/5">
              <span class="material-symbols-outlined text-xl">
                {cs.data.tags[0] === 'Manufacturing' ? 'precision_manufacturing' : 'health_and_safety'}
              </span>
            </div>
            <h3 class="font-heading text-xl font-bold mb-3">{cs.data.title}</h3>
            <div class="text-sm text-white/70 leading-relaxed">
              <Content />
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-white/10 flex items-center justify-between">
            <span class="font-heading font-bold text-secondary text-3xl">{cs.data.stat}</span>
            <span class="text-xs font-semibold text-white/50 uppercase tracking-wider">{cs.data.statLabel}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
