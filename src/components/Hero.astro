---
interface Props {
  badge: string;
  title: string;
  description: string;
  ctaPrimary: { text: string; href: string };
  ctaSecondary: { text: string; href: string };
}

const { badge, title, description, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center px-margin-mobile md:px-margin-desktop py-20 overflow-hidden reveal active">
  <div class="max-w-container-max mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10">
    <div class="lg:col-span-8 flex flex-col justify-center gap-8">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-secondary-container/10 border border-secondary/20 w-fit">
        <span class="material-symbols-outlined text-secondary text-sm">rocket_launch</span>
        <span class="text-xs font-semibold tracking-wider text-secondary uppercase">{badge}</span>
      </div>
      <h1 class="font-heading text-5xl md:text-6xl lg:text-[72px] text-primary-container font-bold leading-[1.1]">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed">
        {description}
      </p>
      <div class="flex flex-wrap gap-4 mt-4">
        <a class="btn-primary px-8 py-4 rounded-md text-sm font-semibold flex items-center gap-2" href={ctaPrimary.href}>
          {ctaPrimary.text}
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
        <a class="btn-outline px-8 py-4 rounded-md text-sm font-semibold" href={ctaSecondary.href}>
          {ctaSecondary.text}
        </a>
      </div>
    </div>
  </div>
</section>
