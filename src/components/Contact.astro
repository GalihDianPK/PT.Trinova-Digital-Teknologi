---
interface Props {
  title: string;
  description: string;
  hqTitle: string;
  hqAddress: string;
  mapLink: string;
}

const { title, description, hqTitle, hqAddress, mapLink } = Astro.props;
---

<section class="py-section-py px-margin-mobile md:px-margin-desktop bg-surface reveal" id="contact">
  <div class="max-w-container-max mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
      <div>
        <h2 class="font-heading text-3xl md:text-4xl text-primary-container font-bold mb-6">{title}</h2>
        <p class="text-base text-on-surface-variant mb-12 leading-relaxed max-w-lg">{description}</p>
        <form class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <label class="block text-xs font-semibold text-primary-container mb-2 uppercase tracking-wider">First Name</label>
              <input class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary-container focus:ring-0 px-0 py-2 transition-colors text-base" placeholder="John" type="text" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-primary-container mb-2 uppercase tracking-wider">Last Name</label>
              <input class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary-container focus:ring-0 px-0 py-2 transition-colors text-base" placeholder="Doe" type="text" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-primary-container mb-2 uppercase tracking-wider">Corporate Email</label>
            <input class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary-container focus:ring-0 px-0 py-2 transition-colors text-base" placeholder="john@company.com" type="email" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-primary-container mb-2 uppercase tracking-wider">Project Inquiry</label>
            <textarea class="w-full bg-transparent border-0 border-b border-outline-variant focus:border-primary-container focus:ring-0 px-0 py-2 transition-colors text-base resize-none" placeholder="Describe your operational objectives..." rows="3"></textarea>
          </div>
          <button class="btn-primary px-8 py-4 rounded-md text-sm font-semibold w-full md:w-auto mt-4" type="submit">
            Submit Inquiry
          </button>
        </form>
      </div>
      <div class="enterprise-card rounded-2xl p-3 h-full min-h-[500px] flex flex-col bg-white">
        <div class="w-full h-full rounded-xl flex-grow min-h-[350px] relative overflow-hidden">
          <!-- Embed Google Maps Interactive Iframe -->
          <iframe 
            src="https://maps.google.com/maps?q=Plaza%20Indonesia,%20Jl.%20M.H.%20Thamrin%20No.Kav.%2028-30,%20Jakarta&t=&z=15&ie=UTF8&iwloc=&output=embed" 
            class="w-full h-full border-0 absolute inset-0 rounded-lg" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          
          <!-- Address Info Overlay Card -->
          <div class="absolute bottom-6 left-6 right-6 p-6 bg-white/95 backdrop-blur-sm shadow-xl border border-outline-variant/30 rounded-xl z-10">
            <h4 class="font-heading text-lg font-bold text-primary-container mb-2">{hqTitle}</h4>
            <a href={mapLink} target="_blank" rel="noopener noreferrer" class="text-sm text-on-surface-variant flex items-start gap-3 hover:text-secondary group transition-colors duration-200">
              <span class="material-symbols-outlined text-secondary text-xl group-hover:scale-110 transition-transform duration-200">location_on</span>
              <span class="hover:underline" set:html={hqAddress} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
