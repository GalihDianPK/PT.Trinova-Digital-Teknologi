---
interface Member {
  name: string;
  role: string;
  image: string;
  bio: string;
}

interface Props {
  title: string;
  subtitle: string;
  members: Member[];
}

const { title, subtitle, members } = Astro.props;
---

<section class="py-section-py px-margin-mobile md:px-margin-desktop bg-surface-container-low border-y border-outline-variant/50 reveal" id="founders">
  <div class="max-w-container-max mx-auto">
    <!-- Header -->
    <div class="mb-16 text-center max-w-3xl mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-container font-bold mb-6">{title}</h2>
      <p class="text-lg text-on-surface-variant leading-relaxed">{subtitle}</p>
    </div>

    <!-- Founders Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 max-w-5xl mx-auto">
      {members.map((member) => (
        <div class="flex flex-col items-center text-center group">
          <!-- Pop-out Avatar Container -->
          <div class="relative w-48 h-48 mb-8 flex items-center justify-center">
            <!-- Background Decorative Circle (Bingkai Belakang) -->
            <div class="absolute w-40 h-40 rounded-full bg-gradient-to-tr from-secondary-container/30 to-secondary/40 border-2 border-dashed border-secondary/50 scale-105 group-hover:rotate-45 transition-transform duration-700 ease-out z-0"></div>
            
            <!-- Photo Circle Frame (Bingkai Utama yang Timbul) -->
            <div class="absolute w-40 h-40 rounded-full border-4 border-white shadow-md bg-white overflow-hidden z-10 transition-all duration-300 ease-out group-hover:-translate-y-4 group-hover:shadow-2xl group-hover:border-secondary">
              <img 
                src={member.image} 
                alt={member.name} 
                class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-110" 
              />
            </div>
            
            <!-- Shadow under the popped-out circle -->
            <div class="absolute w-36 h-4 rounded-full bg-black/10 blur-md bottom-2 scale-90 opacity-0 group-hover:opacity-100 group-hover:scale-100 transition-all duration-300 ease-out z-0"></div>
          </div>

          <!-- Description -->
          <h3 class="font-heading text-xl font-bold text-primary-container mb-2 group-hover:text-secondary transition-colors duration-200">{member.name}</h3>
          <p class="text-sm font-semibold tracking-wider text-secondary uppercase mb-4">{member.role}</p>
          <p class="text-base text-on-surface-variant leading-relaxed max-w-xs">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>
