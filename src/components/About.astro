---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  title: string;
  paragraphs: string[];
  stats: Stat[];
}

const { title, paragraphs, stats } = Astro.props;
---

<section class="relative py-section-py px-margin-mobile md:px-margin-desktop bg-surface-container-low border-y border-outline-variant/50 reveal overflow-hidden" id="about">
  <!-- Background Image with Premium Overlay -->
  <div class="absolute inset-0 z-0 select-none pointer-events-none">
    <img src="/images/about-bg.png" alt="Corporate Meeting" class="w-full h-full object-cover object-center md:object-left opacity-20 md:opacity-35" />
    <div class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-surface-container-low/80 via-surface-container-low/95 md:from-transparent md:via-surface-container-low/50 md:to-surface-container-low"></div>
  </div>

  <div class="max-w-container-max mx-auto relative z-10">
    <div class="max-w-2xl ml-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-container font-bold mb-6">{title}</h2>
      {paragraphs.map((p) => (
        <p class="text-base text-on-surface-variant mb-6 leading-relaxed">{p}</p>
      ))}
      <div class="grid grid-cols-2 gap-8 pt-6 border-t border-outline-variant/50 mt-4">
        {stats.map((stat) => (
          <div>
            <p class="font-heading text-4xl font-bold text-primary-container mb-2">{stat.value}</p>
            <p class="text-sm font-medium text-on-surface-variant uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
