---
interface LinkItem {
  text: string;
  href: string;
}

interface LinkGroup {
  title: string;
  links: LinkItem[];
}

interface Props {
  tagline: string;
  copyright: string;
  linkGroups: LinkGroup[];
}

const { tagline, copyright, linkGroups } = Astro.props;
---

<footer class="bg-[#00020a] text-white w-full py-20 border-t border-white/10 font-sans text-sm">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="md:col-span-4 pr-8">
      <div class="font-heading text-2xl font-bold text-white mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined text-2xl text-secondary">token</span>
        Trinova
      </div>
      <p class="text-white/60 leading-relaxed mb-8">{tagline}</p>
      <p class="text-xs text-white/40" set:html={copyright} />
    </div>
    <div class="md:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-8">
      {linkGroups.map((group, i) => (
        <div class={i === linkGroups.length - 1 ? 'col-span-2 md:col-span-1' : ''}>
          <h4 class="font-semibold text-white mb-6 uppercase tracking-wider text-xs">{group.title}</h4>
          <ul class="space-y-4">
            {group.links.map((link) => (
              <li><a class="text-white/60 hover:text-white transition-colors" href={link.href}>{link.text}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
